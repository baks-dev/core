{
  "name": "baks-dev/core",
  "description": "Модуль Core",
  "homepage": "https://github.com/baks-dev/core",
  "keywords": ["bundle", "symfony", "core", "system"],
  "license": "MIT",
  "type": "symfony-bundle",
  "authors": [
    {
      "name": "Baks Development",
      "email": "admin@baks.dev"
    }
  ],

  "require": {
    "ext-mbstring": "*",
    "php": ">=8.1",
    "symfony/twig-bundle": "^6.2"
  },

  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "symfony/test-pack": "^1.0"
  },

  "autoload": {
    "psr-4": {
      "BaksDev\\Core\\": ""
    }
  },

  "autoload-dev": {
    "psr-4": {
      "BaksDev\\Core\\Tests\\": "Tests/"
    }
  },

  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "symfony/flex": true
    }
  }
}
