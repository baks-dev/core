{
  "name": "baks-dev/core",
  "description": "Модуль Core",
  "homepage": "https://github.com/baks-dev/core",
  "keywords": [
    "symfony",
    "bundle",
    "library",
    "plugin",
    "module",
    "core",
    "system",
    "baksdev"
  ],
  "license": "MIT",
  "type": "symfony-bundle",
  "authors": [
    {
      "name": "Baks Development",
      "email": "admin@baks.dev"
    }
  ],
  "require": {
    "ext-mbstring": "*",
    "php": ">=8.1",
    "symfony/twig-pack": "^1.0",
    "twig/intl-extra": "^3.5",
    "twig/extra-bundle": "^3.5",
    "symfony/form": "^6.2",
    "symfony/security-bundle": "^6.2",
    "symfony/security-csrf": "^6.2",
    "symfony/console": "^6.2",
    "symfony/monolog-bundle": "^3.8",
    "symfony/validator": "^6.2",
    "symfony/expression-language": "^6.2",
    "symfony/rate-limiter": "^6.2",
    "symfony/intl": "^6.2",
    "symfony/cache": "^6.2",
    "symfony/event-dispatcher": "^6.2",
    "symfony/http-kernel": "^6.2",
    "symfony/filesystem": "^6.2",
    "symfony/finder": "^6.2",
    "symfony/messenger": "^6.2",
    "symfony/doctrine-messenger": "^6.2",
    "symfony/translation": "^6.2",
    "symfony/orm-pack": "^2.3",
    "symfony/mailer": "^6.2"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "symfony/test-pack": "^1.0",
    "doctrine/doctrine-fixtures-bundle": "^3.4",
    "symfony/profiler-pack": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "BaksDev\\Core\\": ""
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BaksDev\\Core\\Tests\\": "Tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "symfony/flex": true
    }
  }
}
