{% trans_default_domain('core') %}

<main class="main d-print-none ">

    <section class="container px-4 mb-5">

        <div class="mt-3 d-flex justify-content-between">
            {{ include(_self|replace({ "content.html.twig": "_breadcrumb.html.twig" })) }}
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">

            <div class="w-100">
                <h1 class="h4 text-uppercase fw-bolder mb-0">
                    {{ 'admin.page.index'|trans }}

                    {# Обновить #}
                    <a href="/refresh" class="btn  btn-link text-muted">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                             class="mb-1" viewBox="0 0 16 16">
                            <path fill-rule="evenodd"
                                  d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"></path>
                            <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"></path>
                        </svg>
                    </a>
                </h1>
            </div>

        </div>

    </section>

    <section class="container px-4 mb-5">
        <div class="row g-4">

            {% if ozon_day %}

                <!-- Блок 1: Озон -->
                <div class="col-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-white border-bottom py-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                                         class="bi bi-wallet2" viewBox="0 0 16 16">
                                        <path d="M12.136.326A1.5 1.5 0 0 1 14 1.78V3h.5A1.5 1.5 0 0 1 16 4.5v9a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 13.5v-9a1.5 1.5 0 0 1 1.432-1.499zM5.562 3H13V1.78a.5.5 0 0 0-.621-.484zM1.5 4a.5.5 0 0 0-.5.5v9a.5.5 0 0 0 .5.5h13a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5z"/>
                                    </svg>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold text-dark">Экономика Озон</h6>
                                    <small class="text-muted">{{ day_start|format_datetime(pattern="d MMMM Y") }}</small>
                                </div>
                            </div>
                        </div>

                        <div class="card-body p-3 d-flex flex-column">

                            {% for ozon_day_item in ozon_day %}

                                {% if ozon_day_item.getType() == 'cache_orders_day' %}
                                    <h6 class="text-uppercase text-muted small fw-bold my-2">По заказам</h6>
                                {% endif %}

                                {% if ozon_day_item.getType() == 'cache_others_day' %}
                                    <h6 class="text-uppercase text-muted small fw-bold my-2">Прочее</h6>
                                {% endif %}

                                {% if ozon_day_item.getType() != 'cache_all_day' %}
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="text-secondary small">{{ ozon_day_item.getName() }}</span>
                                        <span class="fw-semibold small {{ ozon_day_item.getTotal().getValue() > 0 ? 'text-success' : 'text-danger' }}">
                                        {{ ozon_day_item.getTotal().getValue()|number_format(2, '.', ' ') }}
                                        </span>
                                    </div>
                                {% else %}
                                    <div class="bg-light rounded-3 p-2 text-end border my-2">
                                        <div class="text-muted small text-uppercase fw-bold mb-1"
                                             style="font-size: 0.75rem;">{{ ozon_day_item.getName() }}</div>
                                        <div class="h6 mb-0 fw-bolder text-primary">
                                            {{ ozon_day_item.getTotal().getValue()|number_format(2, '.', ' ') }}
                                        </div>
                                    </div>
                                {% endif %}

                                {# {{ ozon_day_item.getType }} #}

                            {% endfor %}

                            {# <div class="mb-3">
                                <h6 class="text-uppercase text-muted small fw-bold mb-2">Прочее</h6>
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="text-secondary small">Прочие выплаты</span>
                                    <span class="fw-semibold text-dark small">...</span>
                                </div>
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="text-secondary small">Прочих удержаний</span>
                                    <span class="fw-semibold text-danger small">...</span>
                                </div>
                            </div> #}

                        </div>
                    </div>
                </div>

            {% endif %}


