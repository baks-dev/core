<div class="container d-flex flex-grow-1 flex-stack align-items-center gap-5 py-3">

    <div class="d-flex align-items-center me-15 w-250px">
        <a href="/">
            <img alt="Logo" data-src="/assets/img/logo.webp"
                 src="/assets/img/empty.webp"
                 class="lazy"
                 height="50px"
            >
        </a>
    </div>


    <div class="region_wrapper w-250px"></div>


    <div class="d-flex w-100">

        <form action="#" class="d-flex align-items-center position-relative w-100">
            <div class="w-100"><input type="search" class="form-control" id="search" placeholder="Поиск по каталогу">
            </div>
            <button class="btn position-absolute top-0 end-0" type="submit" aria-label="Поиск по каталогу">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                     class="bi bi-search text-secondary" viewBox="0 0 16 16">
                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"></path>
                </svg>
            </button>
        </form>
    </div>


    <div class="text-center col-2">
        <a rel="nofollow" class="text-black"
           href="tel:+78005550364">+7 (800) 555-03-64</a>
        <div class="small">
            <span class="small">Заказать звонок</span>
        </div>
    </div>


    <div class="col-2 d-flex align-items-center flex-shrink-0">


        {# ПРОФИЛЬ ПОЛЬЗОВАТЕЛЯ #}
        {% if app.user %}

            {#<a
                    href="{{ path('AuthEmail:user.logout') }}"
                    class="btn btn-link h-40px z-index-3 modal-link d-flex align-items-center text-dark gap-3"

                    data-bs-toggle="modal"
                    data-bs-target="#modal"

                    aria-label="Вход в личный кабинет"
                    title="Вход в личный кабинет"
            >

                <span class="icon rounded-1 mb-2 bg-contain"
                      style="width: 43px; height: 43px;">

                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                         class="text-secondary" viewBox="0 0 16 16">
                        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H3Zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/>
                    </svg>

                </span>

                <span class="h6 lh-normal">Войти</span>
            </a>#}

            {# МЕНЮ ПОЛЬЗОВТАЕЛЯ #}
            {{ include(_self|replace({ "header.html.twig": "includes/user.menu.html.twig" })) }}


            {# ВОЙТИ #}
        {% else %}

            <a
                    href="{{ path('AuthEmail:user.login') }}"
                    class="btn btn-link modal-link d-flex align-items-center text-dark gap-3"

                    data-bs-toggle="modal"
                    data-bs-target="#modal"

                    aria-label="Вход в личный кабинет"
                    title="Вход в личный кабинет"
            >

                <span class="icon rounded-1 bg-contain"
                      style="width: 43px; height: 43px;">

                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                         class="text-secondary" viewBox="0 0 16 16">
                        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H3Zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/>
                    </svg>

                </span>

                <span class="h6 lh-normal">Войти</span>
            </a>

        {% endif %}


    </div>


</div>

